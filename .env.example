# -----------------------------------------------------------------------------
# Copy to `.env` at this repo root. Backend loads it via app/core/config.py
# -----------------------------------------------------------------------------
#
# LOCAL DEV (uvicorn + alembic on your machine, DB in Podman/Docker):
#   Use 127.0.0.1 — the hostnames `postgres` / `redis` ONLY work INSIDE Compose.
#
# DOCKER COMPOSE (backend service on the same network as postgres/redis):
#   Use @postgres:5432 and redis://redis:6379/0 (see compose.yml overrides).
# -----------------------------------------------------------------------------

# Local machine → DB container (ports published on localhost)
DATABASE_URL=postgresql+asyncpg://orbit:orbit@127.0.0.1:5432/orbit
REDIS_URL=redis://127.0.0.1:6379/0

# Inside Compose stack only (do not use for host-run alembic/uvicorn):
# DATABASE_URL=postgresql+asyncpg://orbit:orbit@postgres:5432/orbit
# REDIS_URL=redis://redis:6379/0

SECRET_KEY=dev-secret-key-change-in-production

# Local dev only: when true, lists every project for every user (breaks sharing tests).
# Leave unset or false for normal org + share behavior.
# DEV_RELAX_PROJECT_ACCESS=true

# AI provider: "vertex" (default, uses GCP ADC) or "anthropic" (direct API key)
CLAUDE_PROVIDER=vertex

# Vertex AI — authenticate with: gcloud auth application-default login
GCP_PROJECT_ID=
GCP_REGION=us-east5

# Direct Anthropic API key — only needed if CLAUDE_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

CLAUDE_DEFAULT_MODEL=claude-sonnet-4-20250514

# Optional: override vault master key (defaults to derived from SECRET_KEY)
# VAULT_MASTER_KEY=

SSO_ISSUER_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# Runtime settings UI (optional)
# GET/PUT /settings/runtime — DB overrides for a subset of limits; see Settings page.
# Per-project: GET/PUT /projects/{id}/runtime-settings — JSON overrides on top of server values.
# Set false in production if you want env-only tuning.
# RUNTIME_SETTINGS_ALLOW_WRITE=true

# -----------------------------------------------------------------------------
# Tunable limits (optional — defaults are in app/core/config.py)
# All are read by pydantic-settings; use UPPER_SNAKE names as below.
# UI overrides win when set (unless cleared in Settings).
# -----------------------------------------------------------------------------
# AI_MAX_TOOL_ROUNDS=40
# AI_CONTEXT_ASSEMBLY_MAX_TOKENS=100000
# MCP_TOOL_CALL_TIMEOUT_SEC=120
# LOCAL_TOOL_DEFAULT_TIMEOUT_SEC=300
# REPO_MAX_FILE_READ_CHARS=100000
# KUBE_LOG_MAX_CHARS=8000
# API_PAGE_DEFAULT=50
# API_PAGE_MAX=200
# ... see Settings class in backend/app/core/config.py for the full list.
