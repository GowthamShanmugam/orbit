DATABASE_URL=postgresql+asyncpg://orbit:orbit@postgres:5432/orbit
REDIS_URL=redis://redis:6379/0
SECRET_KEY=dev-secret-key-change-in-production

# AI provider: "vertex" (default, uses GCP ADC) or "anthropic" (direct API key)
CLAUDE_PROVIDER=vertex

# Vertex AI — authenticate with: gcloud auth application-default login
GCP_PROJECT_ID=
GCP_REGION=us-east5

# Direct Anthropic API key — only needed if CLAUDE_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

CLAUDE_DEFAULT_MODEL=claude-sonnet-4-20250514

# Optional: override vault master key (defaults to derived from SECRET_KEY)
# VAULT_MASTER_KEY=

SSO_ISSUER_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
